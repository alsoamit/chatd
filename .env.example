# Required: who you are on the relay
CHATD_USERNAME=alice

# Required: shared secret you've agreed with the relay operator. If the
# relay is configured with CHATRELAY_TOKEN=open then any non-empty value
# works.
CHATD_TOKEN=open

# Required: WebSocket URL of the relay. Ports / paths are operator-defined.
CHATD_RELAY_URL=ws://127.0.0.1:7878/ws

# Optional: terminal emulator to use for popup windows. Auto-detected
# when blank. Supported: ghostty (default), kitty, alacritty, foot, xterm.
# CHATD_TERMINAL=ghostty
