<?xml version="1.0" encoding="UTF-8"?>
<!--
  chatd LaunchAgent template.

  The installer replaces __BIN_DIR__ and __HOME__ at install time and
  drops the result at ~/Library/LaunchAgents/io.chatd.plist.

  RunAtLoad starts chatd at login. KeepAlive.SuccessfulExit=false
  restarts the daemon if it crashes but not if it exits cleanly (eg.
  the user stopped it via launchctl bootout). ProcessType=Background
  asks macOS to deprioritise it for power management.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>io.chatd</string>

    <key>ProgramArguments</key>
    <array>
        <string>__BIN_DIR__/chatd</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
        <key>Crashed</key>
        <true/>
    </dict>

    <key>ProcessType</key>
    <string>Background</string>

    <key>StandardOutPath</key>
    <string>__HOME__/Library/Logs/chatd.log</string>
    <key>StandardErrorPath</key>
    <string>__HOME__/Library/Logs/chatd.log</string>

    <!-- Inherit a useful PATH so chatd can find ghostty / kitty / etc. -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>__BIN_DIR__:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
</dict>
</plist>
